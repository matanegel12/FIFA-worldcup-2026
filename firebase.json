            "android": "1:584262741109:android:19640ae7fb9171944f9c3c",
            "ios": "1:584262741109:ios:561c4f08f27313614f9c3c",
            "macos": "1:584262741109:ios:561c4f08f27313614f9c3c",
            "web": "1:584262741109:web:c24ff87576cd2ade4f9c3c",
