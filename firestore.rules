rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;

      // Sign-up only: a user may create their own doc, but must start at 0 —
      // otherwise anyone could sign up with an inflated totalPoints.
      allow create: if request.auth.uid == userId
          && request.resource.data.totalPoints == 0;

      // Self-editable fields are display-only. totalPoints and scoreReachedAt
      // are written exclusively by the admin's rescore batch — see
      // admin_panel_vm.dart _rescoreAllUsers()/recomputeAllScores(). A user
      // could otherwise PATCH their own totalPoints directly via the SDK/REST
      // API, bypassing the scoring engine entirely (this is exactly how
      // Adel's points were set to 666 — see incident 2026-07-19).
      allow update: if request.auth.token.email == 'matan.egel@remepy.com'
          || (
            request.auth.uid == userId
            && resource.data.diff(request.resource.data).affectedKeys()
                .hasOnly(['displayName', 'lastVisitedAt'])
          );

      allow delete: if request.auth.token.email == 'matan.egel@remepy.com';
    }

    match /games/{gameId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.email == 'matan.egel@remepy.com';
    }

    match /guesses/{guessId} {
      allow read: if request.auth != null;
      // A user may only write their own guess doc. Admin bypass is required
      // for the Wall of Shame's clearLateGuesses() batch update, which edits
      // other users' guesses.
      allow create, update: if request.auth.uid == request.resource.data.userId
          || request.auth.token.email == 'matan.egel@remepy.com';
      allow delete: if request.auth.token.email == 'matan.egel@remepy.com';
    }

    match /meta/{document} {
      allow read, write: if request.auth.token.email == 'matan.egel@remepy.com';
    }
  }
}
